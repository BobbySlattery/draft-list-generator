# Copy this file to ".env" (in the same directory) and fill in your values.
# When Toast support sends back your Standard API Access credentials, paste them here.

TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
TOAST_RESTAURANT_GUID=

# Defaults (only override if you need to)
TOAST_HOST=https://ws-api.toasttab.com
DRAFT_GROUP_NAME=Draft Beer
BAR_NAME=On Tap

# Optional: if your facility has a fixed number of taps (e.g., 24), set this
# so the grid is always 3×8 even when some taps are currently empty.
# Leave blank to display only the beers Toast returns.
EXPECTED_TAP_COUNT=
